name: Full Stack CI
run-name: ${{github.actor}} triggered CI pipeline 
on: 
  push:
    branches:
      - dev
  pull_request:
    branches:
      - dev

jobs:
  build:
    run-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4

    - name: docker compose build and create
    - uses: docker compose up -d --build
  
    - name: Run tests
    - uses: docker compose exec backend cargo test

    - name: Tear down
      if: always()
      run: docker compose down
    




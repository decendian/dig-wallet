name: Jira reminder
on:
    issues:
      types:
        - opened 

jobs:
  comment: 
    runs-on: ubuntu-latest

    steps: 
      - name: Reminder to add ticket to Jira
        run: gh issue comment $ISSUE -b "Make sure to put this ticket into Jira and ideally assign to the appropriate user"
        
    env:
      GH_TOKEN: ${{secrets.GITHUB_TOKEN}}
      ISSUE: ${{github.event.issue.html_url}}